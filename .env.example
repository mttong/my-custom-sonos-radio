# ── ngrok ─────────────────────────────────────────────────────────────────────
# 1. Create a free account at https://ngrok.com
# 2. Copy your auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# 3. Claim a free static domain at https://dashboard.ngrok.com/domains
#    e.g. your-name-sonos.ngrok-free.app  — this never changes across restarts
NGROK_DOMAIN=your-subdomain.ngrok-free.app

# Set NGROK_URL to https://<your NGROK_DOMAIN> so the server knows its public
# base URL without waiting to query the ngrok API at startup.
NGROK_URL=https://your-subdomain.ngrok-free.app

# ── Sonos Control API ─────────────────────────────────────────────────────────
# From https://developer.sonos.com → your Control Integration → Client Credentials
SONOS_CLIENT_ID=your_sonos_client_id
SONOS_CLIENT_SECRET=your_sonos_client_secret

# ── Optional overrides ────────────────────────────────────────────────────────
# SERVER_PORT=8080
# MEDIA_DIR=/app/media_assets
# MEDIA_BASE_URL=http://YOUR_LAN_IP:8080  # auto-detected at startup if not set

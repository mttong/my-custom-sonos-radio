# ── Public domain ─────────────────────────────────────────────────────────────
# Your domain pointing at the VM's IP (e.g. yourname-sonos.duckdns.org)
# Caddy handles HTTPS/Let's Encrypt automatically — no other config needed.
PUBLIC_DOMAIN=yourname-sonos.duckdns.org
PUBLIC_URL=https://yourname-sonos.duckdns.org

# Audio and album art are served from the same public domain (no LAN IP needed)
MEDIA_BASE_URL=https://yourname-sonos.duckdns.org

# ── Sonos Control API ─────────────────────────────────────────────────────────
# From https://developer.sonos.com → your Control Integration → Client Credentials
SONOS_CLIENT_ID=your_sonos_client_id
SONOS_CLIENT_SECRET=your_sonos_client_secret

# ── ngrok ─────────────────────────────────────────────────────────────────────
# Same ngrok credentials as local dev — tunnel runs on the VM instead of laptop
NGROK_AUTHTOKEN=your_ngrok_auth_token
NGROK_DOMAIN=your-subdomain.ngrok-free.app
PUBLIC_URL=https://your-subdomain.ngrok-free.app

# Audio and album art served through ngrok (no LAN IP needed on VM)
MEDIA_BASE_URL=https://your-subdomain.ngrok-free.app

# ── Sonos Control API ─────────────────────────────────────────────────────────
SONOS_CLIENT_ID=your_sonos_client_id
SONOS_CLIENT_SECRET=your_sonos_client_secret
